{
  "name": "ely",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "db:generate": "pnpm --filter @ely/db generate",
    "db:migrate": "pnpm --filter @ely/db migrate",
    "db:seed": "pnpm --filter @ely/db seed",
    "db:seed-demo": "pnpm --filter @ely/db seed-demo",
    "db:create-admin": "pnpm --filter @ely/db create-admin",
    "db:push": "pnpm --filter @ely/db push"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "prettier": "^3.4.2"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  }
}
