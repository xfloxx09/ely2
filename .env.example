# Database
DATABASE_URL=

# Auth / app
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_WS_URL=disabled

# LLM — use Gemini free tier (no OpenAI key needed)
GEMINI_API_KEY=
# Optional: gemini-2.0-flash (default), gemini-1.5-flash
# GEMINI_MODEL=gemini-2.0-flash
# Optional: force provider when both keys are set — gemini | openai
# LLM_PROVIDER=gemini

# OpenAI (optional, paid)
# OPENAI_API_KEY=

# Avatar image generation (optional)
# REPLICATE_API_TOKEN=

# Encryption keys (change in production)
PERSONALITY_ENCRYPTION_KEY=
API_KEY_ENCRYPTION_KEY=
