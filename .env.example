# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/ely

# Redis
REDIS_URL=redis://localhost:6379

# Auth
NEXTAUTH_SECRET=generate-a-random-32-char-secret
NEXTAUTH_URL=https://web-production-b3008.up.railway.app

# App URL (used for referral links, Stripe redirects)
NEXT_PUBLIC_APP_URL=https://web-production-b3008.up.railway.app

# API — use /api for same-origin (web-only Railway deploy)
NEXT_PUBLIC_API_URL=/api
# Set to WS service URL when deployed, or "disabled" for HTTP chat fallback
NEXT_PUBLIC_WS_URL=disabled

# AI
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
REPLICATE_API_TOKEN=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Encryption
PERSONALITY_ENCRYPTION_KEY=
API_KEY_ENCRYPTION_KEY=

# Email
RESEND_API_KEY=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
